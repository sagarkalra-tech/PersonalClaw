# Google Gemini API Key (Get one at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Port (Default: 3000)
PORT=3000

# Telegram Bot Token (Optional, get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram Chat ID (Optional, locks the bot to you)
AUTHORIZED_CHAT_ID=your_chat_id_here

# Paperclip AI Orchestrator (Optional - run "npx paperclipai onboard --yes" to set up)
PAPERCLIP_API_KEY=your_paperclip_api_key_here
PAPERCLIP_API_URL=http://localhost:3100

