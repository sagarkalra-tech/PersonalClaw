{
  "name": "personalclaw",
  "version": "12.6.1",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --exclude \"dashboard/**\" --exclude \"memory/**\" --exclude \"screenshots/**\" --exclude \"browser_data/**\" src/index.ts",
    "dev:persist": "tsx src/index.ts",
    "dashboard": "npm run dev --prefix dashboard",
    "all": "concurrently \"npm run dev\" \"npm run dashboard\"",
    "browser": "powershell -ExecutionPolicy Bypass -File ./scripts/launch_persistent_browser.ps1",
    "start": "node dist/index.js",
    "build": "tsc"
  },
  "keywords": [],
  "author": "Sagar Kalra",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/screenshot-desktop": "^1.15.0",
    "@types/socket.io": "^3.0.1",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@types/multer": "^2.1.0",
    "axios": "^1.13.6",
    "clipboardy": "^5.3.1",
    "dotenv": "^17.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "playwright": "^1.58.2",
    "screenshot-desktop": "^1.15.3",
    "socket.io": "^4.8.3",
    "systeminformation": "^5.31.4",
    "telegraf": "^4.16.3",
    "tsx": "^4.21.0",
    "ws": "^8.19.0"
  }
}
